# OpenAI key used for /api/intelligence and /api/transcribe
OPENAI_API_KEY=

# Chat model for /api/intelligence (default: gpt-5-mini)
OPENAI_MODEL=

# Transcription model for /api/transcribe (default: gpt-4o-mini-transcribe)
OPENAI_TRANSCRIPTION_MODEL=

# Optional shared token; when set, requests must send Authorization: Bearer <token> or X-Cue-Token
CUE_API_TOKEN=

# Optional comma-separated allowed CORS origins (default: *)
CORS_ORIGIN=
