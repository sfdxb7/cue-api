# OpenAI key used for /api/intelligence and /api/transcribe
OPENAI_API_KEY=

# Chat model for /api/intelligence (default: gpt-5-mini)
OPENAI_MODEL=

# Transcription model for /api/transcribe (default: gpt-4o-mini-transcribe)
OPENAI_TRANSCRIPTION_MODEL=

# Shared token; REQUIRED in production (server refuses to start without it).
# Requests must send Authorization: Bearer <token> or X-Cue-Token.
CUE_API_TOKEN=

# Optional comma-separated allowed CORS origins (default: *).
# For the Chrome extension use its origin, e.g. chrome-extension://<extension-id>
CORS_ORIGIN=

# Set to "true" only when behind a trusted reverse proxy (Traefik/Dokploy);
# enables X-Forwarded-For for rate-limit client identification
TRUST_PROXY=

# Timeout for upstream OpenAI calls in milliseconds (default: 30000)
OPENAI_TIMEOUT_MS=
